{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      ".firebaserc",
      "firestore.rules",
      ".git/**",
      ".venv/**",
      ".claude/**",
      "build/**",
      "dist/**",
      "firestore/**",
      "node_modules/**",
      "*.py",
      "*.csv",
      "*.md",
      "*.spec",
      "*.jsonl",
      "uv.lock",
      "raid_erp_*.html",
      "raid_finder_*.html",
      "index_.html",
      "erp-backup-*.json",
      "erp-full-context.json",
      "conversation_summary.md"
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  },
  "firestore": {
    "rules": "firestore/firestore.rules",
    "indexes": "firestore/firestore.indexes.json"
  }
}
