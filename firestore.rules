rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─────────────────────────────────────────
    // 헬퍼 함수
    // ─────────────────────────────────────────
    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // LEGACY 기간(D+14까지): 'master' + 'site_master' 둘 다 허용
    // D+14 코드 정리 시 'master' 조건 제거
    function isMaster() {
      return request.auth != null
        && userDoc().role in ['master', 'site_master'];
    }

    function isLeader() {
      return request.auth != null
        && userDoc().role in ['leader', 'vice', 'master', 'site_master'];
    }

    // raids/{raidId}/members 서브컬렉션에서 공대 내 역할 확인
    function getRaidRole(raidId) {
      return get(/databases/$(database)/documents/raids/$(raidId)/members/$(request.auth.uid)).data.roleInRaid;
    }

    function isRaidLeader(raidId) {
      return request.auth != null
        && getRaidRole(raidId) in ['guild_master', 'vice_guild_master'];
    }

    function canEditCharacter(raidId) {
      return isMaster() || isRaidLeader(raidId);
    }

    // ─────────────────────────────────────────
    // leader_applications
    // ─────────────────────────────────────────
    match /leader_applications/{appId} {

      // 읽기: 본인 신청 또는 마스터
      allow read: if request.auth != null
        && (resource.data.uid == request.auth.uid || isMaster());

      // 생성: 인증된 유저 + member/guest + pending 상태
      //        + hasPendingLeaderApp이 없거나 false
      //        + leaderAppRejectedAt 기준 24시간 경과
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.status == 'pending'
        && userDoc().role in ['member', 'guest']
        && (
          !('hasPendingLeaderApp' in userDoc())
          || userDoc().hasPendingLeaderApp == false
        )
        && (
          !('leaderAppRejectedAt' in userDoc())
          || userDoc().leaderAppRejectedAt == null
          || request.time > userDoc().leaderAppRejectedAt + duration.value(24, 'h')
        );

      // 수정/삭제: 마스터만
      allow update, delete: if isMaster();
    }

    // ─────────────────────────────────────────
    // users
    // ─────────────────────────────────────────
    match /users/{uid} {
      allow read: if request.auth != null;
      // 본인 프로필 수정 허용, 단 권한/제재 관련 필드는 마스터만
      allow update: if request.auth != null && (
        (
          request.auth.uid == uid
          && !request.resource.data.diff(resource.data).affectedKeys()
              .hasAny(['role','status','suspendedUntil','suspendReason','suspendedBy','suspendedAt'])
        )
        || (
          isMaster()
          // 마스터가 다른 마스터의 제재 필드는 쓸 수 없음
          && !(resource.data.role in ['master','site_master'] && uid != request.auth.uid
               && request.resource.data.diff(resource.data).affectedKeys()
                  .hasAny(['status','suspendedUntil','suspendReason','suspendedBy','suspendedAt']))
        )
      );
      allow create: if request.auth != null && request.auth.uid == uid;
      allow delete: if isMaster();
    }

    // ─────────────────────────────────────────
    // activityLogs (감사 로그 — 수정/삭제 불가)
    // ─────────────────────────────────────────
    match /activityLogs/{logId} {
      allow read: if isMaster();
      allow create: if isMaster();
      // update, delete 는 누구도 불가 (영구 증거)
    }

    // ─────────────────────────────────────────
    // members (LEGACY: D+10 삭제 예정)
    // ─────────────────────────────────────────
    match /members/{memberId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && userDoc().role in ['master', 'site_master', 'leader', 'vice'];
      allow update: if request.auth != null && (
        userDoc().role in ['master', 'site_master', 'leader', 'vice']
        || resource.data.ownerUid == request.auth.uid
      );
      allow delete: if request.auth != null
        && userDoc().role in ['master', 'site_master', 'leader', 'vice'];
    }

    // ─────────────────────────────────────────
    // raids + 서브컬렉션
    // ─────────────────────────────────────────
    match /raids/{raidId} {
      allow read: if true;
      allow create: if isLeader();
      allow update, delete: if isLeader();

      // raids/{raidId}/characters (캐릭터 데이터 — 구 members)
      match /characters/{characterId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null
          && canEditCharacter(raidId);
        allow update: if request.auth != null
          && (canEditCharacter(raidId)
              // 본인 ownerUid 문서는 일부 필드 본인 수정 허용
              || resource.data.ownerUid == request.auth.uid);
        allow delete: if request.auth != null
          && canEditCharacter(raidId);
      }

      // raids/{raidId}/members (유저 멤버십 — roleInRaid)
      match /members/{userId} {
        allow read: if request.auth != null;
        // 생성/수정/삭제: 해당 공대 공대장 또는 사이트마스터
        allow write: if request.auth != null
          && (isMaster()
              || (getRaidRole(raidId) == 'guild_master'));
      }
    }

    // collectionGroup: characters (전체 캐릭터 구독용)
    match /{path=**}/characters/{characterId} {
      allow read: if request.auth != null;
    }

    // ─────────────────────────────────────────
    // linkRequests (계정 연결 승인 요청)
    // ─────────────────────────────────────────
    match /linkRequests/{requestId} {
      // 읽기: 본인 요청 또는 해당 공대 공대장/부공대장 또는 마스터
      allow read: if request.auth != null
        && (resource.data.requesterId == request.auth.uid
            || isMaster()
            || isRaidLeader(resource.data.raidId));

      // 생성: 본인 요청만, pending 상태로
      allow create: if request.auth != null
        && request.resource.data.requesterId == request.auth.uid
        && request.resource.data.status == 'pending';

      // 수정(승인/거부): 해당 공대 공대장/부공대장 또는 마스터
      allow update: if request.auth != null
        && (isMaster() || isRaidLeader(resource.data.raidId));

      // 삭제: 마스터만
      allow delete: if isMaster();
    }

    // ─────────────────────────────────────────
    // 기타 컬렉션 (기존과 동일)
    // ─────────────────────────────────────────
    match /purchases/{id} {
      allow read: if request.auth != null;
      allow create: if isLeader();
      allow delete: if isLeader();
    }
    match /guildPromos/{id} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null
        && (resource.data.ownerUid == request.auth.uid || isMaster());
    }
    match /raidApplications/{id} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if isLeader();
      allow delete: if isLeader();
    }
    match /loginLogs/{id} {
      allow read: if isMaster();
      allow create: if request.auth != null;
    }
    match /stats/{id} {
      allow read, write: if true;
    }
    match /customBosses/{id} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    match /settlements/{id} {
      allow read: if request.auth != null;
      allow write: if isLeader();
    }
    match /bossTimers/{id} {
      allow read, write: if request.auth != null && request.auth.uid == id;
    }
    match /myChars/{id} {
      allow read, write: if request.auth != null && request.auth.uid == id;
    }

    // ─────────────────────────────────────────
    // roles (권한 매트릭스)
    // ─────────────────────────────────────────
    match /roles/{roleId} {
      allow read: if request.auth != null;
      allow write: if isMaster();
    }

    // ─────────────────────────────────────────
    // auditLogs (감사 로그 — 클라이언트 쓰기 불가)
    // ─────────────────────────────────────────
    match /auditLogs/{logId} {
      allow read: if isMaster();
      // write는 누구도 직접 불가 (서버 트리거 전용)
    }
  }
}
