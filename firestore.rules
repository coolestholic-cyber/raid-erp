rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
    // н—¬нҚј н•ЁмҲҳ
    // в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    function isMaster() {
      return request.auth != null && userDoc().role == 'master';
    }
    function isLeader() {
      return request.auth != null && userDoc().role in ['leader', 'vice', 'master'];
    }

    // в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
    // leader_applications
    // в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
    match /leader_applications/{appId} {

      // мқҪкё°: ліёмқё мӢ мІӯ лҳҗлҠ” л§ҲмҠӨн„°
      allow read: if request.auth != null
        && (resource.data.uid == request.auth.uid || isMaster());

      // мғқм„ұ: мқёмҰқлҗң мң м Җ + member/guest + pending мғҒнғң
      //        + hasPendingLeaderAppмқҙ м—Ҷкұ°лӮҳ false
      //        + leaderAppRejectedAt кё°мӨҖ 24мӢңк°„ кІҪкіј
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.status == 'pending'
        && userDoc().role in ['member', 'guest']
        && (
          !('hasPendingLeaderApp' in userDoc())
          || userDoc().hasPendingLeaderApp == false
        )
        && (
          !('leaderAppRejectedAt' in userDoc())
          || userDoc().leaderAppRejectedAt == null
          || request.time > userDoc().leaderAppRejectedAt + duration.value(24, 'h')
        );

      // мҲҳм •/мӮӯм ң: л§ҲмҠӨн„°л§Ң
      allow update, delete: if isMaster();
    }

    // в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
    // users
    // в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
    match /users/{uid} {
      allow read: if request.auth != null;
      // ліёмқё н”„лЎңн•„ мҲҳм • н—Ҳмҡ©, лӢЁ к¶Ңн•ң/м ңмһ¬ кҙҖл Ё н•„л“ңлҠ” л§ҲмҠӨн„°л§Ң
      allow update: if request.auth != null && (
        (
          request.auth.uid == uid
          && !request.resource.data.diff(resource.data).affectedKeys()
              .hasAny(['role','status','suspendedUntil','suspendReason','suspendedBy','suspendedAt'])
        )
        || (
          isMaster()
          // л§ҲмҠӨн„°к°Җ лӢӨлҘё л§ҲмҠӨн„°мқҳ м ңмһ¬ н•„л“ңлҠ” м“ё мҲҳ м—ҶмқҢ
          && !(resource.data.role == 'master' && uid != request.auth.uid
               && request.resource.data.diff(resource.data).affectedKeys()
                  .hasAny(['status','suspendedUntil','suspendReason','suspendedBy','suspendedAt']))
        )
      );
      allow create: if request.auth != null && request.auth.uid == uid;
      allow delete: if isMaster();
    }

    // в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
    // activityLogs (к°җмӮ¬ лЎңк·ё вҖ” мҲҳм •/мӮӯм ң л¶Ҳк°Җ)
    // в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
    match /activityLogs/{logId} {
      allow read: if isMaster();
      allow create: if isMaster();
      // update, delete лҠ” лҲ„кө¬лҸ„ л¶Ҳк°Җ (мҳҒкө¬ мҰқкұ°)
    }

    // в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
    // members (кіөлҢҖмӣҗ лҚ°мқҙн„°)
    // в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
    match /members/{memberId} {
      allow read: if request.auth != null;

      // мғқм„ұ: кіөлҢҖмһҘ/л¶ҖкіөлҢҖмһҘ/л§ҲмҠӨн„°л§Ң (мҠ№мқё н”ҢлЎңмҡ°м—җм„ң м„ңлІ„ мёЎ мғқм„ұ)
      allow create: if request.auth != null
        && userDoc().role in ['master', 'leader', 'vice'];

      // мҲҳм •: кіөлҢҖмһҘкёү лҳҗлҠ” ліёмқё л¬ём„ң (ownerUid кё°мӨҖ)
      allow update: if request.auth != null && (
        userDoc().role in ['master', 'leader', 'vice']
        || resource.data.ownerUid == request.auth.uid
      );

      // мӮӯм ң: кіөлҢҖмһҘкёүл§Ң
      allow delete: if request.auth != null
        && userDoc().role in ['master', 'leader', 'vice'];
    }

    // в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
    // кё°нғҖ м»¬л үм…ҳ (кё°мЎҙкіј лҸҷмқј)
    // в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
    match /purchases/{id} {
      allow read: if request.auth != null;
      allow create: if isLeader();
      allow delete: if isLeader();
    }
    match /guildPromos/{id} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null
        && (resource.data.ownerUid == request.auth.uid || isMaster());
    }
    match /raids/{id} {
      allow read: if true;
      allow create: if isLeader();
      allow update, delete: if isLeader();
    }
    match /raidApplications/{id} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if isLeader();
      allow delete: if isLeader();
    }
    match /loginLogs/{id} {
      allow read: if isMaster();
      allow create: if request.auth != null;
    }
    match /stats/{id} {
      allow read, write: if true;
    }
    match /customBosses/{id} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    match /settlements/{id} {
      allow read: if request.auth != null;
      allow write: if isLeader();
    }
    match /bossTimers/{id} {
      allow read, write: if request.auth != null && request.auth.uid == id;
    }
    match /myChars/{id} {
      allow read, write: if request.auth != null && request.auth.uid == id;
    }
  }
}
