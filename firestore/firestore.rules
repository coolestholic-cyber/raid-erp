rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─────────────────────────────────────────
    // 헬퍼 함수
    // ─────────────────────────────────────────

    // userDoc(): leader_applications 등 기존 규칙에서 계속 사용
    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // [수정 1] get() 중복 호출 방지: request.auth != null 선체크 후 단일 get()
    // LEGACY(D+14까지): 'master' + 'site_master' 둘 다 허용
    // D+14 정리 시 'master' 조건 제거
    function isMaster() {
      return request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
           in ['master', 'site_master'];
    }

    function isLeader() {
      return request.auth != null
        && userDoc().role in ['leader', 'vice', 'master', 'site_master'];
    }

    // [수정 2] exists() 선체크로 문서 없을 때 에러 방지
    // let으로 경로 캐싱해 get() 중복 호출 방지
    function isRaidLeader(raidId) {
      let membershipPath =
        /databases/$(database)/documents/raids/$(raidId)/members/$(request.auth.uid);
      return request.auth != null
        && exists(membershipPath)
        && get(membershipPath).data.roleInRaid in ['guild_master', 'vice_guild_master'];
    }

    // raids/{raidId}/members 쓰기에서 guild_master 역할 단독 확인용
    function isGuildMaster(raidId) {
      let membershipPath =
        /databases/$(database)/documents/raids/$(raidId)/members/$(request.auth.uid);
      return request.auth != null
        && exists(membershipPath)
        && get(membershipPath).data.roleInRaid == 'guild_master';
    }

    // ─────────────────────────────────────────
    // leader_applications
    // ─────────────────────────────────────────
    match /leader_applications/{appId} {
      allow read: if request.auth != null
        && (resource.data.uid == request.auth.uid || isMaster());

      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.status == 'pending'
        && userDoc().role in ['member', 'guest']
        && (
          !('hasPendingLeaderApp' in userDoc())
          || userDoc().hasPendingLeaderApp == false
        )
        && (
          !('leaderAppRejectedAt' in userDoc())
          || userDoc().leaderAppRejectedAt == null
          || request.time > userDoc().leaderAppRejectedAt + duration.value(24, 'h')
        );

      allow update, delete: if isMaster();
    }

    // ─────────────────────────────────────────
    // users
    // ─────────────────────────────────────────
    match /users/{uid} {
      allow read: if request.auth != null;
      allow update: if request.auth != null && (
        (
          request.auth.uid == uid
          && !request.resource.data.diff(resource.data).affectedKeys()
              .hasAny(['role','status','suspendedUntil','suspendReason',
                       'suspendedBy','suspendedAt'])
        )
        || (
          isMaster()
          && !(resource.data.role in ['master','site_master']
               && uid != request.auth.uid
               && request.resource.data.diff(resource.data).affectedKeys()
                  .hasAny(['status','suspendedUntil','suspendReason',
                           'suspendedBy','suspendedAt']))
        )
      );
      allow create: if request.auth != null && request.auth.uid == uid;
      allow delete: if isMaster()
        // Discord 재로그인 시 이전 익명 doc 자기 정리 허용
        // 조건: 삭제 대상 doc이 익명이고, 자신의 새 doc과 동일한 discordId를 가짐
        || (request.auth != null
            && uid != request.auth.uid
            && resource.data.isAnonymous == true
            && resource.data.discordId != null
            && resource.data.discordId
               == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.discordId);
    }

    // ─────────────────────────────────────────
    // activityLogs (감사 로그 — 수정/삭제 불가)
    // ─────────────────────────────────────────
    match /activityLogs/{logId} {
      allow read: if isMaster();
      allow create: if isMaster();
      // update, delete 는 누구도 불가 (영구 증거)
    }

    // ─────────────────────────────────────────
    // members (LEGACY — D+10 삭제 예정)
    // cross-doc read(userDoc) 제거: 클라이언트 낙관적 쓰기 평가 실패 방지
    // ─────────────────────────────────────────
    match /members/{memberId} {
      allow read, write: if request.auth != null;
    }

    // ─────────────────────────────────────────
    // raids + 서브컬렉션
    // ─────────────────────────────────────────
    match /raids/{raidId} {
      allow read: if true;
      allow create: if isLeader();
      allow update, delete: if isLeader();

      // raids/{raidId}/characters (캐릭터 데이터 — 구 members)
      // [수정 3] 연결 관련 필드는 승인 플로우에서만 수정 가능
      match /characters/{characterId} {
        allow read: if request.auth != null;

        allow create: if request.auth != null
          && (isRaidLeader(raidId) || isMaster());

        // 일반 메타 필드만 수정 허용 (연결 관련 필드 클라이언트 직접 수정 불가)
        allow update: if request.auth != null
          && (isRaidLeader(raidId) || isMaster())
          && !request.resource.data.diff(resource.data).affectedKeys()
              .hasAny(['ownerId', 'isLinked', 'linkedAt',
                       'linkedDiscordId', 'linkMethod',
                       'reviewedBy', 'reviewerRole']);

        allow delete: if request.auth != null
          && (isRaidLeader(raidId) || isMaster()
              || resource.data.ownerUid == request.auth.uid
              || resource.data.uid == request.auth.uid);
      }

      // raids/{raidId}/members (유저 멤버십 — roleInRaid)
      // [수정 4] 공대 생성 시 본인이 guild_master로 자기 자신 등록 허용 (순환 참조 방지)
      match /members/{userId} {
        allow read: if request.auth != null;

        allow create: if request.auth != null && (
          // 공대 생성자가 본인을 guild_master로 등록
          (request.auth.uid == userId
           && request.resource.data.roleInRaid == 'guild_master')
          || isGuildMaster(raidId)
          || isMaster()
        );

        allow update: if request.auth != null
          && (isGuildMaster(raidId) || isMaster());

        allow delete: if request.auth != null
          && (isGuildMaster(raidId) || isMaster());
      }
    }

    // collectionGroup: characters (전체 캐릭터 구독용 — subscribeCharacters())
    // [수정 5] 읽기만 허용, 쓰기는 raids/{raidId}/characters 규칙에서 처리
    match /{path=**}/characters/{characterId} {
      allow read: if request.auth != null;
    }

    // ─────────────────────────────────────────
    // linkRequests (계정 연결 승인 요청)
    // [수정 6] update 조건 구체화: pending → approved/rejected 전환만 허용
    // ─────────────────────────────────────────
    match /linkRequests/{requestId} {
      allow read: if request.auth != null
        && (resource.data.requesterId == request.auth.uid
            || isRaidLeader(resource.data.raidId)
            || isMaster());

      allow create: if request.auth != null
        && request.resource.data.requesterId == request.auth.uid
        && request.resource.data.status == 'pending';

      // 승인/거부: 해당 공대 리더 또는 마스터 + pending 상태에서만 전환
      allow update: if request.auth != null
        && (isRaidLeader(resource.data.raidId) || isMaster())
        && resource.data.status == 'pending'
        && request.resource.data.status in ['approved', 'rejected'];

      // 히스토리 보존 — 삭제 불가
      allow delete: if false;
    }

    // ─────────────────────────────────────────
    // 기타 컬렉션 (기존과 동일)
    // ─────────────────────────────────────────
    match /purchases/{id} {
      allow read: if request.auth != null;
      allow create: if isLeader();
      allow delete: if isLeader();
    }
    match /guildPromos/{id} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null
        && (resource.data.ownerUid == request.auth.uid || isMaster());
    }
    match /raidApplications/{id} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if isLeader();
      allow delete: if isLeader();
    }
    match /loginLogs/{id} {
      allow read: if isMaster();
      allow create: if request.auth != null;
    }
    match /stats/{id} {
      allow read, write: if true;
    }
    match /customBosses/{id} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    match /settlements/{id} {
      allow read: if request.auth != null;
      allow write: if isLeader();
    }
    match /bossTimers/{id} {
      allow read, write: if request.auth != null && request.auth.uid == id;
    }
    match /myChars/{id} {
      allow read, write: if request.auth != null && request.auth.uid == id;
    }

    // ─────────────────────────────────────────
    // roles (권한 매트릭스)
    // ─────────────────────────────────────────
    match /roles/{roleId} {
      allow read: if request.auth != null;
      allow write: if isMaster();
    }

    // ─────────────────────────────────────────
    // auditLogs
    // [수정 7] 클라이언트가 본인 actorId로 create만 가능, 수정/삭제 불가
    // ─────────────────────────────────────────
    match /auditLogs/{logId} {
      allow read: if isMaster();
      allow create: if request.auth != null
        && request.resource.data.actorId == request.auth.uid;
      allow update, delete: if false;
    }
  }
}
